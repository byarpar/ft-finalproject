# Google OAuth Configuration - Frontend
# Add these to your /lisu-dict-frontend/.env file

# ========================================
# Google OAuth Client ID
# ========================================
# Same client ID as backend - get from: https://console.cloud.google.com/apis/credentials
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id-from-cloud-console.apps.googleusercontent.com

# ========================================
# Existing Variables (keep these)
# ========================================
# REACT_APP_API_URL=http://localhost:3001

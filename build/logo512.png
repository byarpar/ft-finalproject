<svg width="512" height="512" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Teal Gradient -->
    <linearGradient id="tealBg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0d9488;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#14b8a6;stop-opacity:1" />
    </linearGradient>
    
    <!-- Gold Gradient -->
    <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#fbbf24;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#f59e0b;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Circular Background -->
  <circle cx="256" cy="256" r="256" fill="url(#tealBg)"/>
  
  <!-- Open Book Icon -->
  <g transform="translate(256, 180)">
    <!-- Book container/background -->
    <rect x="-85" y="-35" width="170" height="100" rx="4" fill="#ffffff" opacity="0.95"/>
    
    <!-- Left page -->
    <path d="M -75 -25
             L -75 75
             Q -75 80 -70 80
             L -5 80
             L -5 -25
             Q -5 -30 -10 -27
             Q -40 -15 -75 -25 Z"
          fill="#f0fdfa"
          stroke="#0d9488"
          stroke-width="2"/>
    
    <!-- Left page text lines -->
    <g opacity="0.4">
      <line x1="-65" y1="-10" x2="-15" y2="-10" stroke="#0d9488" stroke-width="2"/>
      <line x1="-65" y1="5" x2="-15" y2="5" stroke="#0d9488" stroke-width="1.5"/>
      <line x1="-65" y1="18" x2="-15" y2="18" stroke="#0d9488" stroke-width="1.5"/>
      <line x1="-65" y1="31" x2="-15" y2="31" stroke="#0d9488" stroke-width="1.5"/>
      <line x1="-65" y1="44" x2="-15" y2="44" stroke="#0d9488" stroke-width="1.5"/>
      <line x1="-65" y1="57" x2="-15" y2="57" stroke="#0d9488" stroke-width="1.5"/>
    </g>
    
    <!-- Right page -->
    <path d="M 5 -25
             L 5 80
             L 70 80
             Q 75 80 75 75
             L 75 -25
             Q 40 -15 10 -27
             Q 5 -30 5 -25 Z"
          fill="#f0fdfa"
          stroke="#0d9488"
          stroke-width="2"/>
    
    <!-- "LISU" text on right page -->
    <text x="40" y="5" 
          font-family="Arial, sans-serif" 
          font-size="22" 
          font-weight="700" 
          text-anchor="middle" 
          fill="#14b8a6">LISU</text>
    
    <!-- Right page text lines -->
    <g opacity="0.4">
      <line x1="15" y1="18" x2="65" y2="18" stroke="#0d9488" stroke-width="1.5"/>
      <line x1="15" y1="31" x2="65" y2="31" stroke="#0d9488" stroke-width="1.5"/>
      <line x1="15" y1="44" x2="65" y2="44" stroke="#0d9488" stroke-width="1.5"/>
      <line x1="15" y1="57" x2="65" y2="57" stroke="#0d9488" stroke-width="1.5"/>
    </g>
    
    <!-- Golden spine -->
    <rect x="-5" y="-35" width="10" height="120" rx="1" fill="url(#goldGrad)"/>
    
    <!-- Spine highlights -->
    <line x1="-3" y1="-30" x2="-3" y2="80" stroke="#ffffff" stroke-width="1" opacity="0.5"/>
    <line x1="3" y1="-30" x2="3" y2="80" stroke="#000000" stroke-width="1" opacity="0.2"/>
  </g>
  
  <!-- "LISU" Text -->
  <text x="256" y="330" 
        font-family="'Arial Black', Arial, sans-serif" 
        font-size="80" 
        font-weight="900" 
        text-anchor="middle" 
        fill="#ffffff"
        letter-spacing="6">LISU</text>
  
  <!-- Decorative line -->
  <line x1="180" y1="360" x2="332" y2="360" stroke="#ffffff" stroke-width="2" opacity="0.5"/>
  
  <!-- "DICTIONARY" Text -->
  <text x="256" y="395" 
        font-family="Arial, sans-serif" 
        font-size="32" 
        font-weight="400" 
        text-anchor="middle" 
        fill="#ffffff"
        opacity="0.95"
        letter-spacing="10">DICTIONARY</text>
  
  <!-- Three dots at bottom -->
  <g opacity="0.6">
    <circle cx="226" cy="440" r="3" fill="#ffffff"/>
    <circle cx="256" cy="440" r="3" fill="#ffffff"/>
    <circle cx="286" cy="440" r="3" fill="#ffffff"/>
  </g>
  
</svg>